  "item": [
    {
      "name": "Cadastro cliente",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const json = pm.response.json();\r",
              "pm.environment.set(\"cliente_id\", json.id);\r",
              "\r",
              "pm.test(\"Cliente cadastrado\", () => {\r",
              "  pm.response.to.have.status(201);\r",
              "});\r",
              "pm.test(\"Cliente tem id\", () => {\r",
              "  pm.expect(json.id).to.be.a(\"number\");\r",
              "});\r",
              "pm.test(\"Nome do cliente correto\", () => {\r",
              "  pm.expect(json.name).to.include(\"ABC\");\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n  \"name\": \"Empresa ABC Ltda\",\r\n  \"email\": \"financeiro@empresaabc.com.br\",\r\n  \"phone\": \"11999990001\",\r\n  \"username\": \"empresa_abc\",\r\n  \"address\": {\r\n    \"city\": \"São Paulo\",\r\n    \"zipcode\": \"01310-100\"\r\n  }\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{base_url}}/users",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "users"
          ]
        }
      },
      "response": []
    },
